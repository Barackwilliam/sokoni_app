rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Biashara - kila mtu aliye login anaweza kusoma (browsing ni public
    // kwenye matumizi halisi, lakini hapa tunalazimisha login kwanza
    // kwa sababu MVP inatumia phone auth kabla ya home screen).
    // Ku-andika/ku-edit ni mwenye biashara pekee (ownerId == uid yake).
    match /businesses/{businessId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
    }

    // Reviews - mtu yeyote aliye login anaweza kusoma na kuandika review,
    // lakini hawezi ku-edit/ku-delete review ya mtu mwingine.
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // Users (optional profile data)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
